# ═══════════════════════════════════════
# CORTEX OS — Environment Configuration
# ═══════════════════════════════════════
# Copy to .env and fill in your values.
# NEVER commit the .env file.

# ── NATS (Message Bus) ──
NATS_URL=nats://nats:4222
NATS_AUTH_TOKEN=change_me_in_production

# ── Ollama (Local LLM) ──
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=dolphin-mistral:latest

# ── ChromaDB (Vector Memory) ──
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Permissions ──
CORTEX_PERMISSION=full

# ── Web UI ──
WEB_PORT=8080

# ── VPN (Optional) ──
TAILSCALE_AUTHKEY=tskey-auth-your-key-here
